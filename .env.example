# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database (JSON file for simplicity)
USERS_DB_PATH=./data/users.json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 2FA Configuration
TWO_FA_ISSUER=Axion Enterprise

# CORS Configuration
# Comma-separated origins accepted exactly + *.axionenterprise.cloud subdomains
CORS_ORIGIN=http://localhost:3000,https://api.axionenterprise.cloud

# Optional ingest protection key for /api/control/ingest/events
CONTROL_INGEST_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
